# PROPASS (Electron app)
# Cloud base URL (required)
PROPASS_CLOUD_URL=http://localhost:8787

# Optional: admin API key (fallback for headless tools only)
# PROPASS_ADMIN_KEY=CHANGE_ME_ADMIN_KEY

# Cloud server (when running cloud/server.js)
PORT=8787
JWT_SECRET=CHANGE_ME_LONG_RANDOM
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY

# Admin account (cloud online login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Optional online DB provider switch (future): sqlite|postgres|mysql
# PROPASS_DB_PROVIDER=sqlite

# SQLite path for the cloud DB (default: cloud/data/database.db)
# PROPASS_SQLITE_PATH=

# SMTP (password recovery emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your_password
SMTP_FROM="PROPASS <no-reply@propass.local>"

# Public base URL used inside reset emails
PUBLIC_BASE_URL=http://localhost:8787
