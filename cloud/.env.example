# Cloud server configuration
PORT=8787
JWT_SECRET=CHANGE_ME_LONG_RANDOM
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY

# SMTP (for password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your_password
SMTP_FROM="PROPASS <no-reply@propass.local>"

# Client app base URL for reset links (if you later host a web UI)
 # Public base URL used in emails (password reset + download links)
 # Example (IONOS): http://87.106.233.224:8787
 PUBLIC_BASE_URL=http://localhost:8787
