{
    "name":  "ppc",
    "version":  "1.0.0",
    "description":  "PPC Electron + React desktop",
    "author":  "PROPASS",
    "main":  "main.js",
    "private":  true,
    "scripts":  {
                    "start":  "electron .",
        "start:nfc:safe:mac": "PROPASS_WRITE_TRAILERS=0 PROPASS_STRICT_TRAILER_CHECK=1 electron .",
        "start:nfc:full:mac": "PROPASS_WRITE_TRAILERS=1 PROPASS_STRICT_TRAILER_CHECK=1 electron .",
        "start:nfc:safe:win": "set PROPASS_WRITE_TRAILERS=0&& set PROPASS_STRICT_TRAILER_CHECK=1&& electron .",
        "start:nfc:full:win": "set PROPASS_WRITE_TRAILERS=1&& set PROPASS_STRICT_TRAILER_CHECK=1&& electron .",
                    "build":  "node ./node_modules/esbuild/bin/esbuild ui_src/main.jsx --bundle --outfile=src/propass-ui.bundle.js --platform=browser --format=iife --jsx=automatic --sourcemap",
                    "electron:dev":  "electron .",
                    "generate:icon":  "node scripts/generate_icon.js",
                    "generate:icon:rounded":  "node scripts/round_logo.js \u0026\u0026 node scripts/generate_icon.js",
                    "predist":  "powershell -ExecutionPolicy Bypass -File ./scripts/prepare_python_runtime.ps1 ; python -m compileall -b backend",
                    "dist":  "electron-builder --win --x64",
                    "dist:mac:arm64":  "electron-builder --mac dmg zip --arm64",
                    "dist:mac:x64":  "electron-builder --mac dmg zip --x64",
                    "dist:mac:universal":  "electron-builder --mac dmg zip --universal",
                    "pack-windows":  "powershell -ExecutionPolicy Bypass -File ./scripts/pack_windows.ps1"
                },
    "devDependencies":  {
                            "electron":  "^25.0.0",
                            "electron-builder":  "^24.0.0",
                            "png-to-ico":  "^2.1.1",
                            "sharp":  "^0.33.5"
                        },
    "build":  {
                  "appId":  "com.propass.app",
                  "asar":  true,
                  "files":  [
                                "**/*",
                                "!backend/**",
                                "!**/*.py",
                                "!**/__pycache__/**"
                            ],
                  "extraResources":  [
                                         {
                                             "from":  "backend",
                                             "to":  "backend",
                                             "filter":  [
                                                            "**/*.py",
                                                            "**/*.pyc"
                                                        ]
                                         },
                                         {
                                             "from":  "runtime/python",
                                             "to":  "python",
                                             "filter":  [
                                                            "**/*"
                                                        ]
                                         }
                                     ],
                  "win":  {
                              "publisherName":  [
                                                    "PROPASS"
                                                ],
                              "icon":  "build/icon.ico",
                              "extraFiles":  [
                                                 {
                                                     "from":  "node_modules/electron/dist/ffmpeg.dll",
                                                     "to":  "ffmpeg.dll"
                                                 }
                                             ],
                              "target":  [
                                             "nsis"
                                         ]
                          },
                  "mac":  {
                              "category":  "public.app-category.business",
                              "target":  [
                                             "dmg",
                                             "zip"
                                         ],
                              "artifactName":  "${productName}-${version}-mac-${arch}.${ext}"
                          },
                  "nsis":  {
                               "oneClick":  true,
                               "perMachine":  false,
                               "installerIcon":  "build/icon.ico",
                               "uninstallerIcon":  "build/icon.ico",
                               "installerHeaderIcon":  "build/icon.ico"
                           }
              },
    "dependencies":  {
                         "better-sqlite3":  "^8.1.0",
                         "chart.js":  "^4.5.1",
                         "cors":  "^2.8.5",
                         "dotenv":  "^16.4.5",
                         "esbuild":  "^0.27.3",
                         "express":  "^4.19.2",
                         "jsonwebtoken":  "^9.0.2",
                         "lucide-react":  "^0.574.0",
                         "nodemailer":  "^6.9.13",
                         "pcsclite":  "^1.0.1",
                         "react":  "^19.2.4",
                         "react-calendar":  "^6.0.0",
                         "react-chartjs-2":  "^5.3.1",
                         "react-dom":  "^19.2.4",
                         "react-router":  "^6.30.1",
                         "react-router-dom":  "^6.30.1",
                         "ws":  "^8.18.0"
                     },
    "productName":  "ProPass"
}